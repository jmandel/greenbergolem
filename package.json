{
  "name": "claim-network",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "tsc --noEmit",
    "orchestrator": "bun orchestrator/run.ts",
    "dummy-chain": "bun orchestrator/run.ts --workflow dummy-chain",
    "viewer:data": "bun viewer/scripts/build-data.ts --run run/run-hcq-004",
    "viewer:sample": "bun viewer/scripts/build-greenberg-sample.ts",
    "viewer:dev": "bun --hot viewer/serve.ts",
    "viewer:build": "bun build viewer/index.html --outdir viewer/dist --target browser --minify --sourcemap && bun run viewer:publish",
    "viewer:publish": "cp viewer/public/index.json viewer/public/bundle.json viewer/public/bundle-greenberg-ibm.json viewer/dist/",
    "test": "bun test"
  },
  "dependencies": {
    "fast-xml-parser": "^5.6.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "yaml": "^2.5.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "playwright-core": "^1.59.1",
    "typescript": "^5.6.3"
  }
}
